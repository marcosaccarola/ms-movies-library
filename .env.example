# ===== MONOREPO: tre .env =====
# 1) Root (opzionale, per variabili condivise)
# 2) frontend/.env — variabili per il frontend (Vite le espone con prefisso VITE_)
# 3) backend/.env — variabili per il server Express

# --- frontend/.env ---
# In produzione, URL del backend (se diverso dall’origine)
# VITE_API_URL=https://your-backend.vercel.app
# Chiave API di offuscamento (stesso valore di backend PUBLIC_API_KEY; finisce nel bundle)
VITE_PUBLIC_API_KEY=your_shared_api_key

# --- backend/.env ---
PORT=3000
# URI MongoDB. Su Vercel: integrazione MongoDB Atlas.
STORAGE_MONGODB_URI=mongodb+srv://user:password@cluster.xxxxx.mongodb.net/nome-database
# Chiave OMDB per ricerca/dettaglio film (le richieste OMDB passano dal backend)
OMDB_API_KEY=your_omdb_api_key
# Chiave API di offuscamento: richiesta in header X-API-Key (stesso valore del frontend)
PUBLIC_API_KEY=your_shared_api_key
