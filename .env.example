# ===== MONOREPO: tre .env =====
# 1) Root (opzionale, per variabili condivise)
# 2) frontend/.env — variabili per il frontend (Vite le espone con prefisso VITE_)
# 3) backend/.env — variabili per il server Express

# --- frontend/.env ---
# In produzione, URL del backend (se diverso dall’origine)
# VITE_API_URL=https://your-backend.vercel.app
# Chiave API di offuscamento (stesso valore di backend PUBLIC_API_KEY; finisce nel bundle)
VITE_PUBLIC_API_KEY=your_shared_api_key

# --- backend/.env ---
PORT=3000
# URI MongoDB. Su Vercel: integrazione MongoDB Atlas.
STORAGE_MONGODB_URI=mongodb+srv://user:password@cluster.xxxxx.mongodb.net/nome-database
# Chiave OMDB per ricerca/dettaglio film (le richieste OMDB passano dal backend)
OMDB_API_KEY=your_omdb_api_key
# Chiave API di offuscamento: richiesta in header X-API-Key (stesso valore del frontend)
PUBLIC_API_KEY=your_shared_api_key
# Auth JWT (obbligatorio per login/register)
JWT_SECRET=your_jwt_secret_min_32_chars
# Opzionali: JWT_ACCESS_EXPIRY (es. 60m), JWT_REFRESH_EXPIRY_DAYS (es. 7)
# Per migrazione utente esistente: MIGRATE_USER_EMAIL, MIGRATE_USER_PASSWORD (default sasha@example.com / changeme)
# Gemini API (chat AI): chiave da https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key
# Verifica email: URL del frontend (per il link nella email). Es. https://tua-app.vercel.app
FRONTEND_URL=https://your-frontend.vercel.app
# SMTP per invio email (verifica indirizzo). Se assente, il link viene solo loggato in console.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM_NAME=Movies Library
# SMTP_FROM_EMAIL=noreply@example.com
# Opzionale: scadenza token verifica email (default 24h)
# EMAIL_VERIFICATION_EXPIRY=24h
