{
  "name": "ms-movies-library",
  "private": true,
  "version": "0.0.0",
  "description": "Monorepo: frontend (Vite/React) + backend (Express)",
  "scripts": {
    "dev": "concurrently -n fe,be -c blue,green \"npm run dev --prefix frontend\" \"npm run dev --prefix backend\"",
    "build:frontend": "npm run build --prefix frontend",
    "build:backend": "npm run build --prefix backend",
    "version:sync": "node scripts/sync-version.js"
  },
  "devDependencies": {
    "concurrently": "^9.0.1"
  }
}
